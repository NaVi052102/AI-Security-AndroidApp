<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.AISecurity" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>

        <item name="android:windowBackground">@color/ig_background</item>
        <item name="android:colorBackground">@color/ig_background</item>
        <item name="android:statusBarColor">@color/ig_background</item>
        <item name="android:navigationBarColor">@color/ig_background</item>

        <item name="colorPrimary">@color/ig_text_primary</item>
        <item name="colorOnPrimary">@color/ig_background</item>
        <item name="colorPrimaryContainer">@color/ig_background</item>
        <item name="colorSecondary">@color/ig_text_primary</item>
        <item name="colorSecondaryContainer">@color/transparent</item>
        <item name="colorSurface">@color/ig_background</item>
        <item name="colorSurfaceVariant">@color/ig_background</item>

        <item name="colorOnSurfaceVariant">@color/sidebar_header_text</item>
        <item name="colorOutline">@color/sidebar_divider_line</item>

        <item name="colorControlHighlight">@color/glass_fill</item>
        <item name="android:textColorPrimary">@color/ig_text_primary</item>
        <item name="android:textColorSecondary">@color/ig_text_secondary</item>
    </style>
    <style name="Theme.Transparent" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
    <style name="Theme.AISecurity" parent="Base.Theme.AISecurity" />

    <style name="PremiumMenuText" parent="TextAppearance.AppCompat.Medium">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/ig_text_primary</item>
    </style>

    <style name="RoundedDrawer">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopRight">32dp</item>
        <item name="cornerSizeBottomRight">32dp</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
    </style>

    <style name="SidebarTheme" parent="">
        <item name="colorOnSurfaceVariant">@color/sidebar_header_text</item>
        <item name="colorOutline">@color/sidebar_divider_line</item>

        <item name="android:textColorSecondary">@color/sidebar_header_text</item>
        <item name="android:divider">@color/sidebar_divider_line</item>
        <item name="android:listDivider">@color/sidebar_divider_line</item>
    </style>

    <style name="Theme.Sentry.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#0A0A0A</item>
        <item name="android:statusBarColor">#0A0A0A</item>
        <item name="android:navigationBarColor">#0A0A0A</item>

    </style>
</resources>