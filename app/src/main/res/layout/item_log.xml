<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#141414"
    app:cardCornerRadius="12dp"
    app:strokeColor="#2A2A2A"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingEnd="12dp"> <View
        android:id="@+id/viewColorBar"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_marginVertical="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="#4CAF50" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingVertical="16dp">

            <TextView
                android:id="@+id/tvLogTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mar 14, 2026 - 11:13:21"
                android:textColor="#6B7B8A"
                android:textSize="10sp"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvLogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Learning"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvLogContext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Context: AI Security. Swipe matrix assimilated."
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <CheckBox
            android:id="@+id/cbSelectLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#2196F3" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>