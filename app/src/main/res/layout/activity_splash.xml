<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <View
        android:id="@+id/splashGlow"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@drawable/bg_gold_glow"
        android:alpha="0.0"
        app:layout_constraintBottom_toTopOf="@id/splashReflection"
        app:layout_constraintTop_toBottomOf="@id/splashText" />

    <ImageView
        android:id="@+id/splashLogo"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/ic_sentry_gold"
        android:alpha="0.0"
        android:scaleX="0.5"
        android:scaleY="0.5"
        app:layout_constraintBottom_toTopOf="@id/splashText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/splashText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="SENTRY"
        android:fontFamily="@font/orbitron_bold"
        android:textColor="#FDE047"
        android:textSize="40sp"
        android:letterSpacing="0.4"
        android:alpha="0.0"
        android:translationY="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splashLogo" />

    <TextView
        android:id="@+id/splashReflection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SENTRY"
        android:fontFamily="@font/orbitron_bold"
        android:textColor="#FF8C00"
        android:textSize="40sp"
        android:letterSpacing="0.4"
        android:alpha="0.0"
        android:scaleY="-1"
        android:translationY="-15dp"
        app:layout_constraintTop_toBottomOf="@id/splashText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>