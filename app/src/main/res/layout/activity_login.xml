<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ig_background"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="120dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_sentry_half_gold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SENTRY"
        android:fontFamily="@font/inter"
        android:textColor="@color/ig_text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Continuous Behavioral Security"
        android:fontFamily="@font/inter"
        android:textColor="@color/ig_text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/etLoginIdentifier"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/glass_card"
        android:hint="Email Address"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="20dp"
        android:textColor="@color/ig_text_primary"
        android:textColorHint="@color/ig_text_secondary"
        android:textSize="15sp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etLoginPassword"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/glass_card"
        android:hint="Password"
        android:inputType="textPassword"
        android:paddingHorizontal="20dp"
        android:textColor="@color/ig_text_primary"
        android:textColorHint="@color/ig_text_secondary"
        android:textSize="15sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot Password?"
        android:textColor="#3B82F6"
        android:fontFamily="@font/inter"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_gravity="end"
        android:paddingVertical="8dp"
        android:layout_marginBottom="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="SECURE LOGIN"
        android:fontFamily="@font/inter"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        app:cornerRadius="30dp"
        app:backgroundTint="#3B82F6"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don't have an account? "
            android:textColor="@color/ig_text_secondary"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tvGoToRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign Up"
            android:textColor="#10B981"
            android:textStyle="bold"
            android:textSize="14sp"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

</LinearLayout>