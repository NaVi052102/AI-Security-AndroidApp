<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ig_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/inter"
            android:text="Configure core AI behavior, automated lockdown responses, and stealth tracking mechanisms."
            android:textColor="@color/ig_text_secondary"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BEHAVIORAL AI ENGINE"
            android:fontFamily="@font/inter"
            android:textColor="@color/ig_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Security Sensitivity"
                android:textColor="@color/ig_text_primary"
                android:fontFamily="@font/inter"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAiDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Moderate false-alarm threshold. Best for normal daily use."
                android:textColor="@color/ig_text_secondary"
                android:fontFamily="@font/inter"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/seekAiSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:max="2"
                android:progress="1"
                android:progressTint="#3B82F6"
                android:thumbTint="#3B82F6"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Normal"
                    android:gravity="start"
                    android:textColor="@color/ig_text_secondary"
                    android:textSize="12sp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Moderate"
                    android:gravity="center"
                    android:textColor="@color/ig_text_secondary"
                    android:textSize="12sp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Strict"
                    android:gravity="end"
                    android:textColor="@color/ig_text_secondary"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PROXIMITY RADAR PROTOCOLS"
            android:fontFamily="@font/inter"
            android:textColor="@color/ig_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Armed Status"
                        android:textColor="@color/ig_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enables distance-based alerts and locking."
                        android:textColor="@color/ig_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchProximityArmed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#1A888888" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Warning Threshold"
                android:textColor="@color/ig_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Watch vibrates and warns user."
                android:textColor="@color/ig_text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgWarningDist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton android:id="@+id/rbWarn1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="1m" android:textColor="@color/ig_text_secondary" android:buttonTint="#3B82F6" android:textSize="13sp"/>
                <RadioButton android:id="@+id/rbWarn2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="2m" android:textColor="@color/ig_text_secondary" android:buttonTint="#3B82F6" android:textSize="13sp"/>
                <RadioButton android:id="@+id/rbWarn3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="3m" android:textColor="@color/ig_text_secondary" android:buttonTint="#3B82F6" android:textSize="13sp"/>
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#1A888888" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lockdown Threshold"
                android:textColor="@color/ig_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Device executes defense protocols."
                android:textColor="@color/ig_text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <RadioGroup
                android:id="@+id/rgLockDist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <RadioButton android:id="@+id/rbLock3" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="3m" android:textColor="@color/ig_text_secondary" android:buttonTint="#EF4444" android:textSize="13sp"/>
                <RadioButton android:id="@+id/rbLock4" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="4m" android:textColor="@color/ig_text_secondary" android:buttonTint="#EF4444" android:textSize="13sp"/>
                <RadioButton android:id="@+id/rbLock5" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="5m" android:textColor="@color/ig_text_secondary" android:buttonTint="#EF4444" android:textSize="13sp"/>
            </RadioGroup>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ACTIVE DEFENSE PROTOCOLS"
            android:fontFamily="@font/inter"
            android:textColor="@color/ig_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sound Alarm Siren"
                        android:textColor="@color/ig_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plays max-volume siren during lockdown."
                        android:textColor="@color/ig_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchSiren"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#1A888888" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transmit GPS via SMS"
                        android:textColor="@color/ig_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvManageContactsLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sends location. Tap here to manage Trusted Contacts."
                        android:textColor="#3B82F6"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchGps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#1A888888" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Defense Mechanism"
                        android:textColor="@color/ig_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select how the phone neutralizes the intruder."
                        android:textColor="@color/ig_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDefense"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <RadioGroup
                android:id="@+id/rgDefenseType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="visible">

                <RadioButton
                    android:id="@+id/rbOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Red Screen Overlay (Persistent Block)"
                    android:textColor="@color/ig_text_secondary"
                    android:fontFamily="@font/inter"
                    android:textSize="13sp"
                    android:buttonTint="#3B82F6"/>

                <RadioButton
                    android:id="@+id/rbScreenOff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aggressive Screen-Off (Device Enforcer)"
                    android:textColor="@color/ig_text_secondary"
                    android:fontFamily="@font/inter"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:buttonTint="#3B82F6"/>

                <RadioButton
                    android:id="@+id/rbOrdinaryLock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ordinary Lock (Standard Android Lock)"
                    android:textColor="@color/ig_text_secondary"
                    android:fontFamily="@font/inter"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:buttonTint="#3B82F6"/>
            </RadioGroup>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STEALTH TRACKING"
            android:fontFamily="@font/inter"
            android:textColor="@color/ig_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hide App Icon"
                        android:textColor="@color/ig_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="To open app when hidden, dial *#8888#"
                        android:textColor="#F59E0B"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchStealth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDemoOverlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:text="TEST RED SCREEN OVERLAY"
            android:fontFamily="@font/inter"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:stateListAnimator="@null"
            android:background="@null" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDemoEnforcer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:text="TEST SCREEN-OFF ENFORCER"
            android:fontFamily="@font/inter"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:stateListAnimator="@null"
            android:background="@null" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDemoOrdinary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="40dp"
            android:background="@null"
            android:fontFamily="@font/inter"
            android:letterSpacing="0.08"
            android:stateListAnimator="@null"
            android:text="TEST ORDINARY LOCK"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>