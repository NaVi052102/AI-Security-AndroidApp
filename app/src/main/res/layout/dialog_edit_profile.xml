<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dialogRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:text="EDIT PROFILE"
        android:textColor="@color/ig_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:layout_marginBottom="24dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardDialogAvatar"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent">

        <TextView
            android:id="@+id/tvDialogInitials"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:fontFamily="@font/inter"
            android:textColor="@color/ig_text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:text="+"/>

        <ImageView
            android:id="@+id/imgDialogAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etFirstName"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="#1A888888"
            android:hint="First Name"
            android:textColorHint="@color/ig_text_secondary"
            android:textColor="@color/ig_text_primary"
            android:paddingHorizontal="16dp"
            android:fontFamily="@font/inter"
            android:textSize="15sp"
            android:inputType="textPersonName"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etMiddleInitial"
            android:layout_width="60dp"
            android:layout_height="52dp"
            android:background="#1A888888"
            android:hint="M.I."
            android:gravity="center"
            android:textColorHint="@color/ig_text_secondary"
            android:textColor="@color/ig_text_primary"
            android:fontFamily="@font/inter"
            android:textSize="15sp"
            android:inputType="textCapCharacters"
            android:maxLength="1"/>
    </LinearLayout>

    <EditText
        android:id="@+id/etLastName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="#1A888888"
        android:hint="Last Name"
        android:textColorHint="@color/ig_text_secondary"
        android:textColor="@color/ig_text_primary"
        android:paddingHorizontal="16dp"
        android:fontFamily="@font/inter"
        android:textSize="15sp"
        android:inputType="textPersonName"
        android:layout_marginBottom="32dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="CANCEL"
            android:fontFamily="@font/inter"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:stateListAnimator="@null"
            android:background="@null" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="SAVE"
            android:fontFamily="@font/inter"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:stateListAnimator="@null"
            android:background="@null" />
    </LinearLayout>
</LinearLayout>