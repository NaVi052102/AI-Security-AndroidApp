<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/item_app_usage"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/glass_card"
    android:orientation="horizontal"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical">

    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1A10B981" />

        <ProgressBar
            android:id="@+id/pbAppTraining"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:minHeight="36dp"
            android:maxHeight="36dp"
            android:scaleY="1.2"
            android:progressTint="#10B981"
            android:progressBackgroundTint="@android:color/transparent"
            android:max="100"
            android:progress="0" />

        <TextView
            android:id="@+id/tvAppProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="0%"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/inter"
            android:textStyle="bold" />
    </FrameLayout>

    <ImageView
        android:id="@+id/ivAppIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="12dp"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/inter"
        android:textColor="@color/ig_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvAppSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/inter"
        android:textColor="@color/ig_text_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.05" />

    <TextView
        android:id="@+id/tvAppCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:textColor="@color/ig_text_primary"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>