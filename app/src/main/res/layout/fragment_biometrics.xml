<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ig_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/btnInfo"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/inter"
                android:text="Monitor real-time AI security learning and manage your continuous behavioral protection."
                android:textColor="@color/ig_text_secondary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <ImageButton
                android:id="@+id/btnInfo"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentEnd="true"
                android:background="?selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="#3B82F6" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/glass_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvRiskScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:text="0%"
                android:textColor="#10B981"
                android:textSize="56sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:text="SYSTEM SECURE"
                android:textColor="@color/ig_text_secondary"
                android:textSize="14sp"
                android:letterSpacing="0.15"
                android:layout_marginTop="4dp"
                android:textStyle="bold"/>

            <ProgressBar
                android:id="@+id/linearProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="160dp"
                android:layout_height="8dp"
                android:layout_marginTop="16dp"
                android:progress="0"
                android:max="100"
                android:progressDrawable="@drawable/glass_card"
                android:progressTint="#10B981" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/inter"
                android:text="AI CONVERGENCE"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/ig_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAction"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1.2"
                android:layout_marginEnd="4dp"
                android:fontFamily="@font/inter"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="START"
                android:background="@null" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnUseAi"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:fontFamily="@font/inter"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="USE AI"
                android:background="@null" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:fontFamily="@font/inter"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="RESET"
                android:background="@null" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:text="NEURAL MAPPING CURVE"
                    android:textColor="#3B82F6"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/tvCurrentLossValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:fontFamily="monospace"
                    android:text="LOSS: 0.0000"
                    android:textColor="#3B82F6"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <com.example.aisecurity.ui.biometrics.LineChartView
                android:id="@+id/aiLearningGraph"
                android:layout_width="match_parent"
                android:layout_height="140dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardAppFlow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:text="APP TRANSITION TRACKER"
                android:textColor="@color/ig_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivPreviousApp"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvPreviousApp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:text="System UI"
                        android:textColor="@color/ig_text_secondary"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="match_parent" android:layout_marginHorizontal="16dp" android:background="#33999999" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivCurrentApp"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tvCurrentApp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:text="Monitoring"
                        android:textColor="@color/ig_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE APP INSIGHTS"
                android:fontFamily="@font/inter"
                android:textColor="@color/ig_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerAppStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingBottom="20dp"
            android:paddingHorizontal="20dp"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_app_usage" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>