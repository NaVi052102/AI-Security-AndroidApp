<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ig_background"
    android:fillViewport="true"
    tools:ignore="HardcodedText,ContentDescription">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/glass_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Security Score"
                android:fontFamily="@font/inter"
                android:textColor="@color/ig_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvSystemPercentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:fontFamily="@font/inter"
                android:textColor="@color/ig_text_primary"
                android:textSize="72sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSystemStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.05"
                android:text="CALCULATING..."
                android:textColor="#F59E0B"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvActionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp"
            android:letterSpacing="0.1"
            android:text="ACTION REQUIRED"
            android:fontFamily="@font/inter"
            android:textColor="#EF4444"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/actionCardPermissions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System Permissions"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvPermissionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Only 2 of 6 allowed."
                    android:fontFamily="@font/inter"
                    android:textColor="#F59E0B"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnAuthorize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALLOW"
                android:fontFamily="@font/inter"
                android:textColor="#3B82F6"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionCardSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lockdown Configuration"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Turn on alarms and screen locks."
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnConfigure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIGURE"
                android:fontFamily="@font/inter"
                android:textColor="#3B82F6"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionCardWatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connect Watch"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App cannot see your watch right now."
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnConnect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECT"
                android:fontFamily="@font/inter"
                android:textColor="#3B82F6"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionCardAi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Train AI"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App does not know your swipe pattern."
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnTrain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRAIN"
                android:fontFamily="@font/inter"
                android:textColor="#3B82F6"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionCardSms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Trusted Contacts"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add a friend to text if phone is stolen."
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnAddContact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADD"
                android:fontFamily="@font/inter"
                android:textColor="#3B82F6"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>


        <TextView
            android:id="@+id/tvActiveTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp"
            android:letterSpacing="0.1"
            android:text="WORKING FEATURES"
            android:fontFamily="@font/inter"
            android:textColor="@color/ig_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/activeContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:id="@+id/activeRowPermissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="System Permissions"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✔"
                    android:fontFamily="@font/inter"
                    android:textColor="#10B981"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/activeRowSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lockdown Configuration"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✔"
                    android:fontFamily="@font/inter"
                    android:textColor="#10B981"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/activeRowWatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Watch Connection"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✔"
                    android:fontFamily="@font/inter"
                    android:textColor="#10B981"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/activeRowAi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AI Training"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✔"
                    android:fontFamily="@font/inter"
                    android:textColor="#10B981"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/activeRowSms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Trusted Contacts"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✔"
                    android:fontFamily="@font/inter"
                    android:textColor="#10B981"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp"
            android:letterSpacing="0.1"
            android:text="RECENT ACTIVITY"
            android:fontFamily="@font/inter"
            android:textColor="@color/ig_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="6dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_shield_check"
                    app:tint="#10B981"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="App opened with Face or Fingerprint"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10:42 AM"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A888888"
                android:layout_marginVertical="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="6dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_shield_check"
                    app:tint="#F59E0B"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="App started tracking in background"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_primary"
                    android:textSize="13sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09:15 AM"
                    android:fontFamily="@font/inter"
                    android:textColor="@color/ig_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>